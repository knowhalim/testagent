{
  "name": "testagent-node-worker",
  "version": "1.0.0",
  "description": "Node worker sidecar for TestAgent — runs Midscene.js UI audits and Playwright UX audits",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@midscene/web": "^0.15.0",
    "@playwright/mcp": "^0.0.75",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.2",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
