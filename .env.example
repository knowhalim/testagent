# ==============================================================
# TestAgent — Environment Configuration
# Copy this file to .env and fill in your values.
# ==============================================================

# ---------- Security ----------
SECRET_KEY=change-me-to-a-random-64-char-string

# ---------- Database ----------
DB_USER=testagent
DB_PASS=testagent
DB_NAME=testagent

# ---------- Ports ----------
FRONTEND_PORT=3000
BACKEND_PORT=8000
NODE_WORKER_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ---------- URLs ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---------- LLM API Keys (at least one required for audits) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- Ollama (optional, for local models) ----------
# Start with: docker compose -f docker-compose.yml -f docker-compose.ollama.yml up -d
OLLAMA_URL=http://localhost:11434
OLLAMA_PORT=11434
